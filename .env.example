# Aagman QA Harness configuration
# Copy this to .env and fill in real values. NEVER commit .env.

# Which Aagman environment to test: prod | staging
AAGMAN_ENV=staging

# Your registered phone number (with country code)
AAGMAN_PHONE=+919421922886

# Optional: pre-seed OTP so the harness runs non-interactively.
# If omitted, the CLI will prompt you.
# AAGMAN_OTP=277594

# GitHub owner/repo where reports will be pushed
GITHUB_OWNER=kotilabs
GITHUB_REPO=aagman-v2

# GitHub token for pushing artifacts and posting issue comments.
# Defaults to GH_TOKEN or GITHUB_TOKEN env vars if not set here.
# GITHUB_TOKEN=ghp_xxx

# GitHub repo used as a public image/artifact host for screenshots.
# The harness pushes screenshots here so they can be embedded in issue bodies.
AAGMAN_QA_SCREENSHOTS_OWNER=iamaryansinha
AAGMAN_QA_SCREENSHOTS_REPO=aagman-qa-screenshots
# Token must have write access to the screenshots repo. Defaults to GH_TOKEN_PERSONAL.
# AAGMAN_QA_SCREENSHOTS_TOKEN=ghp_xxx

# Name shown in generated GitHub issue reports.
# AAGMAN_QA_TESTER=Aryan

# Optional: use a saved Chrome profile so you don't have to enter OTP every run.
# Run `browser-use profile list` to see available profiles.
# BROWSER_USE_PROFILE=kotilabs.com

# LLM configuration for intelligent replies to unexpected agent questions.
# Required for the LLM answer provider to handle clarifying questions.
# Supported providers: deepseek (default if base URL/model contains deepseek)
DEEPSEEK_API_KEY=sk-xxx
# AAGMAN_QA_LLM_PROVIDER=deepseek
# AAGMAN_QA_LLM_MODEL=deepseek-chat
# AAGMAN_QA_LLM_BASE_URL=https://api.deepseek.com/v1

# Vision API configuration for screenshot-based verification (e.g., chart detection).
# Defaults to OPENAI_API_KEY / KIMI_API_KEY / DEEPSEEK_API_KEY if VISION_API_KEY is not set.
# VISION_API_KEY=sk-xxx
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini
